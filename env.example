# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://myepbuddy.com

# Encryption Key for user API keys (REQUIRED)
# Generate with: openssl rand -hex 32
# This key encrypts user-provided API keys at rest in the database
# WARNING: Changing this key will invalidate all existing encrypted API keys
ENCRYPTION_KEY=your_64_character_hex_encryption_key

# Fallback LLM API Keys (used when users don't provide their own)
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key
XAI_API_KEY=your_xai_grok_api_key

# Stripe Billing (AI call credits)
# Use sk_test_ + a test price locally; sk_live_ + live price in production.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
# Local dev: run `npm run stripe:listen` in a second terminal (uses STRIPE_SECRET_KEY
# from .env.local). Copy the whsec_... printed by the CLI into STRIPE_WEBHOOK_SECRET
# and restart `npm run dev`. Plain `stripe listen` without --api-key forwards events
# from the CLI login account, which may NOT match your app's checkout account.
# One-time $1 / 100 AI calls (legacy: STRIPE_PRICE_150_CREDITS, STRIPE_STARTER_PRICE_ID)
STRIPE_PRICE_100_CREDITS=price_your_100_credits_price_id

# Production (live) starter package — Oaiken LLC / MyEPBuddy
# Product: prod_UelHo41h4odIsL — "MyEPBuddy AI Credits — Starter"
# Price:   price_1TfRl1RmU7HJ5YzinnKdFWDl — $1.00 USD, 100 AI calls (update in live Stripe)
# Webhook: https://myepbuddy.com/api/billing/webhook
# Events:  checkout.session.completed, checkout.session.async_payment_succeeded

# Analytics: Self-hosted via Supabase - no configuration needed
# All behavior data stays in your database (analytics_events table)

